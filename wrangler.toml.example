# Cloudflare Workers 配置文件
# 复制此文件为 wrangler.toml 并填写实际值

name = "credits-wall"
compatibility_date = "2024-01-01"

# Pages 配置
pages_build_output_dir = ".svelte-kit/cloudflare"

# D1 数据库绑定
[[d1_databases]]
binding = "DB"  # 在代码中通过 env.DB 访问
database_name = "kids-points-db"
database_id = "your-database-id-here"  # 从 wrangler d1 create 命令的输出中获取

# 环境变量（可选）
[vars]
ENVIRONMENT = "production"

# 开发环境配置
[env.development]
name = "credits-wall-dev"

[[env.development.d1_databases]]
binding = "DB"
database_name = "kids-points-db-dev"
database_id = "your-dev-database-id-here"

# 路由配置（可选）
# routes = [
#   { pattern = "example.com/*", zone_name = "example.com" }
# ]
