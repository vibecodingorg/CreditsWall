{
  "name": "kids-points",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:cf": "npm run build && cp -r functions .svelte-kit/cloudflare/",
