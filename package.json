    "svelte": "^5.1.0",
    "svelte-i18n": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@sveltejs/adapter-cloudflare": "^4.6.0",
    "@sveltejs/kit": "^2.48.4",
    "@vite-pwa/sveltekit": "^0.5.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^6.3.3",
    "wrangler": "^3.80.0"
  }
